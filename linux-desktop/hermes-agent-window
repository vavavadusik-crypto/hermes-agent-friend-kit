#!/usr/bin/env bash
set -u

cd "$HOME"
clear
printf 'Starting Hermes Agent...\n\n'

if command -v hermes-agent-auto-route >/dev/null 2>&1; then
  printf 'Checking provider route...\n'
  if ! hermes-agent-auto-route --quiet >/tmp/hermes-agent-switcher-last.log 2>&1; then
    printf 'No working cloud provider right now. Local Ollama is disabled to protect weak laptops.\n'
    printf 'Open Hermes Agent Settings, wait for limits to reset, or set HERMES_AGENT_ALLOW_LOCAL=1 manually.\n\n'
    exec bash -i
  fi
  printf '\n'
fi

if command -v hermes >/dev/null 2>&1; then
  hermes
else
  printf 'Hermes command not found. Run install.sh first.\n'
fi
status=$?

printf '\nHermes Agent exited with status %s.\n' "$status"
printf 'This window stays open so status/errors are visible.\n'
printf 'Press Ctrl+D or type exit to close it.\n\n'
exec bash -i
